{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plume",
  "version": "0.3.0",
  "identifier": "app.plume.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Plume",
        "width": 1080,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["txt", "text", "log", "ini", "cfg", "conf"],
        "name": "Text Document",
        "description": "Plain text document",
        "role": "Editor"
      },
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": ["csv", "tsv"],
        "name": "Delimited Text",
        "description": "Delimited text data",
        "role": "Editor"
      },
      {
        "ext": ["json", "yaml", "yml", "toml", "xml"],
        "name": "Structured Text",
        "description": "Structured text document",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
